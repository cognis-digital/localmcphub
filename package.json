{
  "name": "@cognis-digital/localmcphub",
  "version": "0.1.0",
  "description": "Registry, launcher, and health dashboard for a fleet of local MCP (Model Context Protocol) servers.",
  "type": "module",
  "bin": {
    "localmcphub": "dist/src/cli.js"
  },
